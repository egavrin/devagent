{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "scripts/**/*.ts"
  ],
  "project": [
    "scripts/**/*.ts"
  ],
  "ignoreFiles": [
    "scripts/live-validation/execute-deep.test.ts",
    "scripts/live-validation/execute-chain.test.ts",
    "scripts/live-validation/live-validation.test.ts",
    "scripts/live-validation/tui-validator.test.ts",
    "scripts/surface-smoke/fixtures/**"
  ],
  "ignoreDependencies": [
    "undici"
  ],
  "ignoreIssues": {
    "scripts/live-validation/execute-chain-lib.ts": ["exports"],
    "scripts/live-validation/isolation.ts": ["exports"],
    "scripts/live-validation/manifest.ts": ["exports"]
  },
  "workspaces": {
    "packages/arkts": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/providers": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/runtime": {
      "entry": [
        "src/tools/**/*.ts"
      ],
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/executor": {
      "project": [
        "src/**/*.ts"
      ]
    },
    "packages/cli": {
      "entry": [
        "src/main.ts"
      ],
      "project": [
        "src/**/*.ts",
        "src/**/*.tsx"
      ]
    }
  }
}
