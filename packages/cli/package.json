{
  "name": "@devagent/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "devagent": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "bun run ../../scripts/embed-assets.ts && tsc && cp src/prompts/*.md dist/prompts/",
    "test": "bun run ../../scripts/embed-assets.ts && vitest run --passWithNoTests",
    "lint": "eslint src/",
    "typecheck": "bun run ../../scripts/embed-assets.ts && tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "install-cli": "bun link"
  },
  "dependencies": {
    "@devagent/arkts": "workspace:*",
    "@devagent/executor": "workspace:*",
    "@devagent/providers": "workspace:*",
    "@devagent/runtime": "workspace:*",
    "@types/react": "^19.2.14",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0"
  }
}
