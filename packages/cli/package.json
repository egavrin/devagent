{
  "name": "@devagent/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "devagent": "dist/index.js"
  },
  "scripts": {
    "build": "bun run ../../scripts/embed-assets.ts && tsc --build --force && cp src/prompts/*.md dist/prompts/",
    "test": "bun run ../../scripts/embed-assets.ts && vitest run --passWithNoTests",
    "lint": "eslint src/ --max-warnings=0",
    "typecheck": "bun run ../../scripts/embed-assets.ts && tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "install-cli": "bun link"
  },
  "dependencies": {
    "@devagent/executor": "workspace:*",
    "@devagent/providers": "workspace:*",
    "@devagent/runtime": "workspace:*",
    "@types/react": "^19.2.14",
    "cli-highlight": "^2.1.11",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "smol-toml": "^1.3.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  }
}
