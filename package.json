{
  "name": "devagent-ts",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@devagent-sdk/schema": "file:../devagent-sdk/packages/schema",
    "@devagent-sdk/types": "file:../devagent-sdk/packages/types",
    "@devagent-sdk/validation": "file:../devagent-sdk/packages/validation"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:arkts": "turbo run lint:arkts",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "install-cli": "cd packages/cli && bun link",
    "install-lsp": "bash scripts/install-lsp-servers.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@typescript-eslint/parser": "^8.56.1",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "minimatch@^3": "3.1.3"
  }
}
