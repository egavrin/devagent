{
  "name": "devagent-ts",
  "private": true,
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:arkts": "turbo run lint:arkts",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "install-cli": "cd packages/cli && bun link",
    "install-lsp": "bash scripts/install-lsp-servers.sh"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "@types/bun": "^1.2.0"
  }
}
